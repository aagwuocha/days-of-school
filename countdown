<!DOCTYPE html>
    .countdown-card {
      text-align: center;
      background: rgba(255, 255, 255, 0.9);
      padding: 40px 55px;
      border-radius: 32px;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
      border: 6px solid white;
      max-width: 760px;
      width: 85%;
    }

    .emoji {
      font-size: 56px;
      margin-bottom: 10px;
    }

    h1 {
      font-size: 48px;
      margin: 0 0 20px;
      color: #2563eb;
    }

    .days {
      font-size: 96px;
      font-weight: 900;
      color: #16a34a;
      line-height: 1;
      margin: 15px 0;
    }

    .label {
      font-size: 38px;
      font-weight: bold;
      margin-bottom: 20px;
    }

    .date {
      font-size: 28px;
      color: #374151;
      margin-top: 20px;
    }

    .message {
      font-size: 24px;
      margin-top: 24px;
      color: #9333ea;
      font-weight: bold;
    }

    .confetti {
      position: absolute;
      font-size: 28px;
      animation: float 6s infinite ease-in-out;
      opacity: 0.8;
    }

    .c1 { top: 8%; left: 12%; animation-delay: 0s; }
    .c2 { top: 15%; right: 14%; animation-delay: 1s; }
    .c3 { bottom: 12%; left: 16%; animation-delay: 2s; }
    .c4 { bottom: 18%; right: 12%; animation-delay: 3s; }
    .c5 { top: 45%; left: 5%; animation-delay: 1.5s; }
    .c6 { top: 50%; right: 6%; animation-delay: 2.5s; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-20px) rotate(10deg); }
    }
  </style>
</head>
<body>
  <div class="confetti c1">🎉</div>
  <div class="confetti c2">✏️</div>
  <div class="confetti c3">📚</div>
  <div class="confetti c4">☀️</div>
  <div class="confetti c5">🚌</div>
  <div class="confetti c6">🎈</div>

  <div class="countdown-card">
    <div class="emoji">🏫✨</div>
    <h1>School Countdown</h1>
    <div class="days">19.5</div>
    <div class="label">School Days Remaining!</div>
    <div class="date">Counting down to June 4</div>
    <div class="message">Almost there — keep going! ☀️</div>
  </div>
</body>
</html>
